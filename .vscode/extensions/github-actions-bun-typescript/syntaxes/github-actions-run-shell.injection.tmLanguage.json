{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GitHub Actions run shell injection",
  "scopeName": "source.yaml.github-actions.run-shell.injection",
  "injectionSelector": "L:source.yaml, L:source.yaml.github-actions, L:source.github-actions, L:source.github-actions-workflow - meta.embedded.block.shellscript",
  "patterns": [
    {
      "include": "#run-block"
    }
  ],
  "repository": {
    "run-block": {
      "contentName": "meta.embedded.block.shellscript",
      "begin": "^(\\s+)(run)(\\s*:\\s*)([>|](?:[-+][1-9]?|[1-9][-+]?)?\\s*)(?:#.*)?$",
      "beginCaptures": {
        "2": {
          "name": "entity.name.tag.yaml"
        },
        "3": {
          "name": "punctuation.separator.key-value.mapping.yaml"
        },
        "4": {
          "name": "string.unquoted.block.yaml"
        }
      },
      "end": "^(?!(?:\\1\\s+|\\s*$))",
      "patterns": [
        {
          "include": "#bun-heredoc-single-quoted"
        },
        {
          "include": "#bun-heredoc-double-quoted"
        },
        {
          "include": "#bun-heredoc-unquoted"
        },
        {
          "include": "source.shell"
        }
      ]
    },
    "bun-heredoc-single-quoted": {
      "name": "meta.bun.heredoc.typescript.shell",
      "contentName": "meta.embedded.block.typescript",
      "begin": "^(\\s*)(?:(?:[A-Za-z_][A-Za-z0-9_]*=(?:[^\\s\"']+|\"[^\"]*\"|'[^']*')\\s+)*)?(?:(?:command|exec|env)\\s+)*(bun)(?:(?:\\s+(?:(?!<<).))+?)?\\s*(<<-?)'([A-Za-z_][A-Za-z0-9_]*)'(?:\\s*(?:#.*)?)$",
      "beginCaptures": {
        "2": {
          "name": "entity.name.function.call.shell"
        },
        "3": {
          "name": "keyword.operator.heredoc.shell"
        },
        "4": {
          "name": "punctuation.definition.string.heredoc.delimiter.shell"
        }
      },
      "end": "^\\1(?:\\t*)\\4$",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.heredoc.delimiter.shell"
        }
      },
      "patterns": [
        {
          "include": "source.ts"
        }
      ]
    },
    "bun-heredoc-double-quoted": {
      "name": "meta.bun.heredoc.typescript.shell",
      "contentName": "meta.embedded.block.typescript",
      "begin": "^(\\s*)(?:(?:[A-Za-z_][A-Za-z0-9_]*=(?:[^\\s\"']+|\"[^\"]*\"|'[^']*')\\s+)*)?(?:(?:command|exec|env)\\s+)*(bun)(?:(?:\\s+(?:(?!<<).))+?)?\\s*(<<-?)\"([A-Za-z_][A-Za-z0-9_]*)\"(?:\\s*(?:#.*)?)$",
      "beginCaptures": {
        "2": {
          "name": "entity.name.function.call.shell"
        },
        "3": {
          "name": "keyword.operator.heredoc.shell"
        },
        "4": {
          "name": "punctuation.definition.string.heredoc.delimiter.shell"
        }
      },
      "end": "^\\1(?:\\t*)\\4$",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.heredoc.delimiter.shell"
        }
      },
      "patterns": [
        {
          "include": "source.ts"
        }
      ]
    },
    "bun-heredoc-unquoted": {
      "name": "meta.bun.heredoc.typescript.shell",
      "contentName": "meta.embedded.block.typescript",
      "begin": "^(\\s*)(?:(?:[A-Za-z_][A-Za-z0-9_]*=(?:[^\\s\"']+|\"[^\"]*\"|'[^']*')\\s+)*)?(?:(?:command|exec|env)\\s+)*(bun)(?:(?:\\s+(?:(?!<<).))+?)?\\s*(<<-?)([A-Za-z_][A-Za-z0-9_]*)(?:\\s*(?:#.*)?)$",
      "beginCaptures": {
        "2": {
          "name": "entity.name.function.call.shell"
        },
        "3": {
          "name": "keyword.operator.heredoc.shell"
        },
        "4": {
          "name": "punctuation.definition.string.heredoc.delimiter.shell"
        }
      },
      "end": "^\\1(?:\\t*)\\4$",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.heredoc.delimiter.shell"
        }
      },
      "patterns": [
        {
          "include": "source.ts"
        }
      ]
    }
  }
}

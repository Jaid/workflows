{
  "publisher": "jaid",
  "name": "github-actions-bun-typescript",
  "displayName": "GitHub Actions Run TypeScript",
  "description": "Workspace-local syntax highlighting for inline TypeScript passed to jaidlab/action-run-typescript in GitHub Actions workflows.",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "github-actions",
    "workflow",
    "yaml",
    "typescript",
    "action-run-typescript",
    "syntax-highlighting"
  ],
  "contributes": {
    "grammars": [
      {
        "scopeName": "source.yaml.github-actions.action-run-typescript.injection",
        "path": "./syntaxes/github-actions-action-run-typescript.injection.tmLanguage.json",
        "injectTo": [
          "source.yaml",
          "source.yaml.github-actions",
          "source.github-actions",
          "source.github-actions-workflow"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.typescript": "typescript"
        },
        "tokenTypes": {
          "meta.embedded.block.typescript": "other"
        }
      }
    ]
  }
}

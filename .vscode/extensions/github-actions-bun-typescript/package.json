{
  "publisher": "jaid",
  "name": "github-actions-bun-typescript",
  "displayName": "GitHub Actions Bun TypeScript",
  "description": "Workspace-local syntax highlighting for Bun TypeScript heredocs inside GitHub Actions run blocks.",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "github-actions",
    "workflow",
    "yaml",
    "shell",
    "bun",
    "typescript",
    "syntax-highlighting"
  ],
  "contributes": {
    "grammars": [
      {
        "scopeName": "source.yaml.github-actions.run-shell.injection",
        "path": "./syntaxes/github-actions-run-shell.injection.tmLanguage.json",
        "injectTo": [
          "source.yaml",
          "source.yaml.github-actions",
          "source.github-actions",
          "source.github-actions-workflow"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.shellscript": "shellscript",
          "meta.embedded.block.typescript": "typescript"
        },
        "tokenTypes": {
          "meta.embedded.block.shellscript": "other",
          "meta.embedded.block.typescript": "other"
        }
      }
    ]
  }
}
